<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/terraTextFieldLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Label"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/terraTextFieldContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <ImageView
            android:id="@+id/terraTextFieldLeftIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:importantForAccessibility="no"
            android:visibility="gone" />

        <TextView
            android:id="@+id/terraTextFieldPrefixText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/terraTextFieldPrefixIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:importantForAccessibility="no"
            android:visibility="gone" />

        <View
            android:id="@+id/terraTextFieldDivider"
            android:layout_width="1dp"
            android:layout_height="21dp"
            android:layout_marginHorizontal="8dp"
            android:background="@android:color/darker_gray"
            android:visibility="gone" />

        <EditText
            android:id="@+id/terraTextFieldInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Place Holder"
            android:importantForAutofill="no"
            android:inputType="text"
            android:minHeight="24dp"
            android:padding="0dp" />

        <TextView
            android:id="@+id/terraTextFieldSuffixText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/terraTextFieldRightIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:importantForAccessibility="no"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/terraTextFieldHelper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Helper Type Here"
        android:visibility="gone" />
</LinearLayout>
