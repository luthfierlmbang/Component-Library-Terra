<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Primary Normal"
            app:terraButtonType="primary"
            app:terraButtonSize="normal" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Primary Small"
            app:terraButtonType="primary"
            app:terraButtonSize="small" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Secondary"
            app:terraButtonType="secondary"
            app:terraButtonSize="normal" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Outlined Primary"
            app:terraButtonType="outlinedPrimary"
            app:terraButtonSize="normal" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Outlined Secondary"
            app:terraButtonType="outlinedSecondary"
            app:terraButtonSize="normal" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Danger"
            app:terraButtonType="danger"
            app:terraButtonSize="normal" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Text Button"
            app:terraButtonType="textButton"
            app:terraButtonSize="normal" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:enabled="false"
            android:text="Disabled Primary"
            app:terraButtonType="primary"
            app:terraButtonSize="normal" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Left Icon"
            app:terraButtonType="primary"
            app:terraButtonSize="normal"
            app:terraLeftIcon="@drawable/information" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Both Icons"
            app:terraButtonType="outlinedPrimary"
            app:terraButtonSize="small"
            app:terraLeftIcon="@drawable/arrow_left"
            app:terraRightIcon="@drawable/chevron_right" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Search"
            app:terraButtonType="secondary"
            app:terraButtonSize="normal"
            app:terraLeftIcon="@drawable/search" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Confirm"
            app:terraButtonType="primary"
            app:terraButtonSize="normal"
            app:terraLeftIcon="@drawable/check" />

        <com.terra.design.components.TerraButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Settings"
            app:terraButtonType="textButton"
            app:terraButtonSize="normal"
            app:terraLeftIcon="@drawable/settings" />

    </LinearLayout>
</ScrollView>
